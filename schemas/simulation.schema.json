{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/earthwalking/AI-Wellbeing/schemas/simulation.schema.json",
  "title": "AI-Wellbeing LLM Simulation Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["simulation_id", "model", "construct", "score", "prompt_id"],
  "properties": {
    "simulation_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the model-generated observation."
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "description": "Model name or model family identifier."
    },
    "construct": {
      "type": "string",
      "minLength": 1,
      "description": "Psychological construct being simulated."
    },
    "score": {
      "type": "number",
      "description": "Numeric score parsed from the model output."
    },
    "prompt_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier linking the output to a prompt template."
    },
    "persona": {
      "$ref": "#/$defs/identity"
    },
    "behavior": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      },
      "description": "Optional behavior-like variables generated by the model."
    },
    "metadata": {
      "type": "object",
      "description": "Run metadata such as date, temperature, seed, and parser version."
    }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gender": { "type": ["string", "null"] },
        "age_group": { "type": ["string", "null"] },
        "education": { "type": ["string", "null"] },
        "income_group": { "type": ["string", "null"] },
        "region": { "type": ["string", "null"] }
      }
    }
  }
}
